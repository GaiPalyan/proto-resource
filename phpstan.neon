includes:
    - vendor/pestphp/pest/extension.neon

parameters:
    level: 6
    paths:
        - src
        - tests
    excludePaths:
        - tests/Stubs/Messages

    treatPhpDocTypesAsCertain: false

    ignoreErrors:
        # toProto() returns base Message class — concrete proto methods not visible to PHPStan
        - identifier: method.notFound
          path: tests/Unit
          message: '#Call to an undefined method Google\\Protobuf\\Internal\\Message::#'

        # Pest expect() template type inference limitations
        - identifier: argument.templateType
          path: tests/Unit

        # Unresolvable types from excluded proto stubs flowing into test assertions
        - identifier: argument.unresolvableType
          path: tests/Unit
        - identifier: function.unresolvableReturnType
          path: tests/Unit
