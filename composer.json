{
  "name": "gpalyan/proto-resource",
  "description": "Laravel gRPC resources for transforming data to protobuf messages",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "ProtoResource\\": "src/"
    }
  },
  "require": {
    "php": "^8.4",
    "illuminate/collections": "^12.0 || ^13.0"
  },
  "require-dev": {
    "phpstan/phpstan": "2.1.46",
    "symfony/var-dumper": "^7.2.0",
    "pestphp/pest": "^3.7",
    "google/protobuf": "^4.0",
    "orchestra/testbench": "^v10.0",
    "laravel/pint": "^1.24"
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
